<mvc:View
    controllerName="com.travel.analytics.travelanalyticsenterprise.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="page"
        showHeader="false">

        <content>
            <VBox
                id="dashboardContainer"
                class="dashboardContainer">

                <core:Fragment
                    fragmentName="com.travel.analytics.travelanalyticsenterprise.fragments.Header"
                    type="XML" />

                <core:Fragment
                    fragmentName="com.travel.analytics.travelanalyticsenterprise.fragments.KPI"
                    type="XML" />

                <core:Fragment
                    fragmentName="com.travel.analytics.travelanalyticsenterprise.fragments.Charts"
                    type="XML" />

                <core:Fragment
                    fragmentName="com.travel.analytics.travelanalyticsenterprise.fragments.RecentTravels"
                    type="XML" />

            </VBox>
        </content>

    </Page>

</mvc:View>