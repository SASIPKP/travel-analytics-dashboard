<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Toolbar
        id="dashboardHeaderToolbar"
        class="dashboardHeaderToolbar sapUiMediumMarginBottom">

        <Title
            id="dashboardHeaderTitle"
            text="Travel Analytics Dashboard"
            level="H1" />

        <ToolbarSpacer id="dashboardHeaderSpacer" />

        <Button
            id="openTravelManagementButton"
            text="View Travel Records"
            icon="sap-icon://table-view"
            type="Emphasized"
            press=".onOpenTravelManagement" />
    </Toolbar>

</core:FragmentDefinition>